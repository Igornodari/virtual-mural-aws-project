# Copie este arquivo para .env.e2e e preencha com credenciais de teste reais
# NUNCA comite .env.e2e no git

# URL base do app (deixe vazio para usar localhost:4200 com ng serve automático)
E2E_BASE_URL=

# Conta de teste — morador (deve existir no Cognito User Pool)
E2E_CUSTOMER_EMAIL=e2e-morador@seudominio.com
E2E_CUSTOMER_PASSWORD=SuaSenhaDeTestAqui

# Conta de teste — prestador (deve existir no Cognito User Pool)
E2E_PROVIDER_EMAIL=e2e-prestador@seudominio.com
E2E_PROVIDER_PASSWORD=SuaSenhaDeTestAqui

# Código de condomínio de teste (deve existir no banco de dados)
E2E_CONDO_CODE=CONDO-TEST-001
